# Port the facilitator listens on
PORT=3002

# Settlement signer — private key of the wallet that submits transferWithAuthorization txs.
# If omitted, /verify still works but /settle returns 501.
PRIVATE_KEY=0x...

# RPC endpoints — add one per EVM network you want to support.
# Format: RPC_<chainId>=<rpcUrl>
RPC_8453=https://mainnet.base.org
RPC_84532=https://sepolia.base.org
RPC_137=https://polygon-rpc.com
RPC_80002=https://rpc-amoy.polygon.technology

# Shared secret for Bearer token authentication.
# The server sends this value as `Authorization: Bearer <token>` on /verify and /settle.
# Leave blank to run the facilitator open (suitable for local development only).
INTERNAL_TOKEN=

# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_PROVIDER="gemini"          # gemini | openai
GEMINI_API_KEY="your-gemini-api-key"
OPENAI_API_KEY="your-openai-api-key"
GEMINI_MODEL="gemini-2.0-flash"  # override to test other models
LLM_TIMEOUT="10000"

# ── AWS Secrets Manager (Lambda / production) ─────────────────────────────────
# Set this to the ARN of a Secrets Manager secret containing
# {"GEMINI_API_KEY": "...", "OPENAI_API_KEY": "..."}
# Leave blank to use the plain-text values above (local dev only).
# Secret name must start with "oraculo-do-bicho" to match the IAM policy.
SECRETS_ARN=""

# ── Server ────────────────────────────────────────────────────────────────────
PORT="3001"

# ── x402 Payments ─────────────────────────────────────────────────────────────
# Leave EVM_ADDRESS blank to disable payment protection (free access to all endpoints)
EVM_ADDRESS="0xYourEvmAddressHere"

# testnet  → eip155:84532  (Base Sepolia)
# mainnet  → eip155:8453   (Base)
X402_NETWORK="eip155:84532"

# default facilitator (testnet + mainnet Base)
FACILITATOR_URL="https://x402.org/facilitator"

# price in USD — /interpretar, /sonho, /numerologia = 1×, /palpite = 2×
PRICE_PER_REQUEST="0.01"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# In production, set this to your CloudFront domain.
# ALLOWED_ORIGINS="https://your-cloudfront-domain.cloudfront.net"
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:4173"

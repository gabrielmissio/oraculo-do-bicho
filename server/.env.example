# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_PROVIDER="gemini"          # gemini | openai
GEMINI_API_KEY="your-gemini-api-key"
OPENAI_API_KEY="your-openai-api-key"
LLM_TIMEOUT="10000"

# ── Server ────────────────────────────────────────────────────────────────────
PORT="3001"

# ── x402 Payments ─────────────────────────────────────────────────────────────
# Leave EVM_ADDRESS blank to disable payment protection (free access to all endpoints)
EVM_ADDRESS="0xYourEvmAddressHere"

# testnet  → eip155:84532  (Base Sepolia)
# mainnet  → eip155:8453   (Base)
X402_NETWORK="eip155:84532"

# Facilitator URL — points to your self-hosted facilitator (recommended) or the public one.
# Default (localhost:3002) assumes you are running the facilitator locally.
# For public testnet-only use: https://x402.org/facilitator
# For Coinbase/Base mainnet:   https://api.cdp.coinbase.com/platform/v2/x402
# ⚠️  In production, always use HTTPS to protect the FACILITATOR_TOKEN in transit.
FACILITATOR_URL="http://localhost:3002"

# Bearer token sent to the custom facilitator (must match INTERNAL_TOKEN in facilitator/.env).
# Leave blank if the facilitator runs without authentication (local dev only).
FACILITATOR_TOKEN=""

# price in USD — /interpretar, /sonho, /numerologia = 1×, /palpite = 2×
PRICE_PER_REQUEST="0.01"
